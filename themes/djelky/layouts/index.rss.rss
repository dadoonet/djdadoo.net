{{- $pages := where .Site.RegularPages "Section" "mixes" -}}
{{- $pages = $pages.ByDate -}}
{{- $site := .Site -}}
{{- $baseURL := $site.BaseURL -}}
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:itunes="http://www.itunes.com/dtds/podcast-1.0.dtd"
xmlns:podcast="https://podcastindex.org/namespace/1.0"
xmlns:atom="http://www.w3.org/2005/Atom"
xmlns:content="http://purl.org/rss/1.0/modules/content/">
<!-- To test the RSS, please use https://podba.se/?url={{ $baseURL }}djdadoo.rss -->
<channel>
  <title>{{ $site.Params.podcast.title | default $site.Title }}</title>
  <link>{{ $baseURL }}</link>
  <atom:link href="{{ $baseURL }}djdadoo.rss" rel="self" type="application/rss+xml" />
  <language>{{ $site.LanguageCode }}</language>
  <copyright>{{ $site.Params.podcast.author }}</copyright>
  <itunes:subtitle>{{ $site.Params.podcast.subtitle }}</itunes:subtitle>
  <itunes:author>{{ $site.Params.podcast.author }}</itunes:author>
  <itunes:summary><![CDATA[<p>{{ $site.Params.podcast.description }}</p>]]></itunes:summary>
  <description><![CDATA[<p>{{ $site.Params.podcast.description }}</p>]]></description>
  <itunes:owner>
    <itunes:name>{{ $site.Params.podcast.author }}</itunes:name>
    <itunes:email>{{ $site.Params.podcast.email }}</itunes:email>
  </itunes:owner>
  <itunes:image href="{{ $baseURL }}{{ $site.Params.podcast.cover }}" />
  <itunes:category text="Music" />
  <itunes:explicit>false</itunes:explicit>
  <!-- Unique id: do not change. It's computed from dj.pilato.fr using https://www.uuidtools.com/v5 -->
  <podcast:guid>{{ $site.Params.podcast.podcastGUID }}</podcast:guid>
  <podcast:locked>no</podcast:locked>
  {{- range $pages }}
  {{- $p := . }}
  {{- $cover := $p.Resources.GetMatch "cover.*" }}
  {{- $audioURL := $p.Params.audio_url | default (printf "%s%s.mp3" $site.Params.podcast.baseAudioURL (path.Dir $p.File.Path)) }}
  <item>
    {{- with $p.Params.season }}
    <itunes:season>{{ . }}</itunes:season>
    {{- end }}
    {{- with $p.Params.episode }}
    <itunes:episode>{{ . }}</itunes:episode>
    {{- end }}
    {{- if $p.Params.itunes_title }}
    <title>{{ $p.Params.itunes_title }}</title>
    {{- else }}
    {{- $rssTitle := printf "%s #%s" $site.Params.podcast.trackTitle ($p.Date.Format "2006/01/02") }}
    {{- with ($p.Params.itunes_subtitle | default $p.Params.title) }}
      {{- $rssTitle = printf "%s - %s" $rssTitle . }}
    {{- end }}
    <title>{{ $rssTitle }}</title>
    {{- end }}
    <itunes:author>{{ with $p.Params.author }}{{ . }}{{ else }}{{ $site.Params.podcast.author }}{{ end }}</itunes:author>
    {{- with ($p.Params.itunes_subtitle | default $p.Params.subtitle) }}
    <itunes:subtitle>{{ . }}</itunes:subtitle>
    {{- end }}
    <description><![CDATA[
      {{- $p.Content }}
      {{- with $p.Params.chapters }}
        <ul>
          {{- range . }}
          <li>{{ .time }} - {{ .title }}</li>
          {{- end }}
        </ul>
      {{- end }}
    ]]></description>
    {{- if $cover }}
    <itunes:image href="{{ $baseURL }}{{ $cover.RelPermalink | strings.TrimPrefix "/" }}" />
    {{- end }}
    <enclosure url="{{ $audioURL }}" length="{{ $p.Params.audio_length | default 0 }}" type="{{ $p.Params.audio_type | default $site.Params.podcast.audioType }}" />
    <guid>{{ $audioURL }}</guid>
    <pubDate>{{ $p.Date.Format "02 Jan 2006 15:04:05 -0700" }}</pubDate>
    {{- with $p.Params.duration }}
    <itunes:duration>{{ . }}</itunes:duration>
    {{- end }}
    {{- $keywords := union $site.Params.podcast.keywords ($p.Params.keywords | default slice) }}
    {{- with $keywords }}
    <itunes:keywords>{{ delimit . ", " }}</itunes:keywords>
    {{- end }}
    <itunes:explicit>{{ if $p.Params.explicit }}true{{ else }}false{{ end }}</itunes:explicit>
    <link>{{ $baseURL }}</link>
  </item>
  {{- end }}
</channel>
</rss>
